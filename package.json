{
  "name": "ocps",
  "version": "0.1.0",
  "description": "Orquestrador Cognitivo de Projetos de Software — Framework CLI para desenvolvimento assistido por IA",
  "type": "module",
  "bin": {
    "ocps": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "mcp": "node dist/mcp/ocps-mcp-server.js",
    "link": "npm link",
    "postinstall": "npm run link"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "ocps": {
    "nodeOptions": "--disable-warning=DEP0040"
  },
  "keywords": [
    "cli",
    "ai",
    "agents",
    "tdd",
    "typescript"
  ],
  "author": "nandodev",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^4.1.0",
    "commander": "^13.0.0",
    "ink": "^5.1.0",
    "js-yaml": "^4.1.0",
    "openai": "^6.27.0",
    "react": "^18.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
